// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  email     String     @unique
  name      String?
  pointages Pointage[]
  horaires  Horaire[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Pointage {
  id          String    @id @default(cuid())
  type        String    // ARRIVEE ou DEPART
  timestamp   DateTime  @default(now())
  location    Json      // { lat: number, lng: number }
  commentaire String?
  status      String    @default("EN_ATTENTE") // EN_ATTENTE, VALIDE, REJETE
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  validation  Validation?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([timestamp])
}

model Validation {
  id          String    @id @default(cuid())
  status      String    // VALIDE ou REJETE
  commentaire String?
  pointage    Pointage  @relation(fields: [pointageId], references: [id], onDelete: Cascade)
  pointageId  String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Horaire {
  id          String    @id @default(cuid())
  jourSemaine Int      // 1 = Lundi, 7 = Dimanche
  heureDebut  String    // Format "HH:mm"
  heureFin    String    // Format "HH:mm"
  pauseDebut  String?   // Format "HH:mm"
  pauseFin    String?   // Format "HH:mm"
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

model Exception {
  id        String    @id @default(cuid())
  date      DateTime
  type      String    // FERME, OUVERT
  motif     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([date])
}
